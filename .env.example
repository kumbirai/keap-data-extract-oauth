# Keap Data Extractor - OAuth2 Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# OAuth2 Authentication Configuration
# =============================================================================
# Get these from your Keap Developer Portal: https://developer.keap.com/
KEAP_CLIENT_ID=your_keap_client_id_here
KEAP_CLIENT_SECRET=your_keap_client_secret_here

# OAuth2 Redirect URI (must match the one registered in Keap Developer Portal)
# For local development, you can use http://localhost:8000/oauth/callback
# For production, must be HTTPS (e.g. https://your-vps-host/oauth/callback behind nginx).
KEAP_REDIRECT_URI=http://localhost:8000/oauth/callback
# When KEAP_REDIRECT_URI is public HTTPS, the authorize script listens here; nginx proxies /oauth/callback.
# OAUTH_CALLBACK_LISTEN_PORT=8000

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=keap_db
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# =============================================================================
# Security Configuration
# =============================================================================
# Token Encryption Key (32 bytes minimum)
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or: python -c "import os; print(os.urandom(32).hex())"
TOKEN_ENCRYPTION_KEY=your_32_byte_encryption_key_here_minimum_32_characters

# =============================================================================
# Optional Configuration
# =============================================================================
# Token refresh threshold in seconds (default: 300 = 5 minutes)
# Tokens will be refreshed if they expire within this threshold
TOKEN_REFRESH_THRESHOLD=300

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Batch size for API requests (default: 50)
BATCH_SIZE=50
