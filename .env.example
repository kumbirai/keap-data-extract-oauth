# Keap Data Extractor - OAuth2 Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# OAuth2 Authentication Configuration
# =============================================================================
# Get these from your Keap Developer Portal: https://developer.keap.com/
KEAP_CLIENT_ID=your_keap_client_id_here
KEAP_CLIENT_SECRET=your_keap_client_secret_here

# OAuth2 Redirect URI (must match the one registered in Keap Developer Portal)
# For local development, you can use http://localhost:8000/oauth/callback
# For production, must be HTTPS (e.g. https://your-vps-host/oauth/callback behind nginx).
KEAP_REDIRECT_URI=http://localhost:8000/oauth/callback
# When KEAP_REDIRECT_URI is public HTTPS, the authorize script listens here; nginx proxies /oauth/callback.
# OAUTH_CALLBACK_LISTEN_PORT=8000

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=keap_db
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# =============================================================================
# Security Configuration
# =============================================================================
# Token Encryption Key (32 bytes minimum)
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or: python -c "import os; print(os.urandom(32).hex())"
TOKEN_ENCRYPTION_KEY=your_32_byte_encryption_key_here_minimum_32_characters

# =============================================================================
# Optional Configuration
# =============================================================================
# Token refresh threshold in seconds (default: 300 = 5 minutes)
# Tokens will be refreshed if they expire within this threshold
TOKEN_REFRESH_THRESHOLD=300

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Batch size for API requests (default: 50)
BATCH_SIZE=50

# =============================================================================
# Stripe BI (optional — omit STRIPE_API_KEY to skip Stripe during full load)
# =============================================================================
# STRIPE_API_KEY=sk_live_...
# Comma-separated Connect account ids; leave unset for platform account only
# STRIPE_ACCOUNT_IDS=acct_xxx,acct_yyy
# STRIPE_API_VERSION=2024-11-20.acacia
# Days to look back on incremental sync to capture status/refund drift (default: 7)
# STRIPE_CHARGE_LOOKBACK_DAYS=7
# Max objects per Stripe list call (capped at 100, default: BATCH_SIZE)
# STRIPE_LIST_LIMIT=100
# STRIPE_STORE_RAW_PAYLOAD=true

# =============================================================================
# Revolut BI (optional — see documentation/revolut/05-access-keys-and-credentials.md)
# =============================================================================
# Short-lived API bearer (e.g. oa_prod_...). Do not set with REVOLUT_REFRESH_TOKEN (OAuth wins).
# REVOLUT_ACCESS_TOKEN=
# REVOLUT_USE_SANDBOX=true
# REVOLUT_CLIENT_ID=
# REVOLUT_ISSUER=   # optional; defaults to REVOLUT_CLIENT_ID
# REVOLUT_JWT_KID=  # optional; if Revolut shows a certificate key id, set it (adds JWT header kid)
# REVOLUT_JWT_AUDIENCE=https://revolut.com   # override if token exchange fails
# REVOLUT_PRIVATE_KEY_PATH=/secure/revolut_private.pem
# REVOLUT_PRIVATE_KEY_PASSPHRASE=
# REVOLUT_REFRESH_TOKEN=   # or use one-shot REVOLUT_AUTHORIZATION_CODE
# REVOLUT_AUTHORIZATION_CODE=
# REVOLUT_TRANSACTION_LOOKBACK_DAYS=7
# REVOLUT_INITIAL_HISTORY_DAYS=730
# REVOLUT_LIST_COUNT=500
# REVOLUT_ACCOUNT_IDS=   # comma-separated UUIDs; omit for all accounts
# REVOLUT_STORE_RAW_PAYLOAD=false
